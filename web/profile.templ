package web

import "github.com/AVZotov/draft-survey/web/layouts"
import "github.com/AVZotov/draft-survey/web/widgets"
import "github.com/AVZotov/draft-survey/web/components"

templ Profile(bannerProps components.BannerProps) {
	@layouts.Layout(ProfilePageProps) {
		@widgets.Header()
		@widgets.ProfileForm()
		@widgets.Footer()
		if bannerProps.Header != "" {
			@widgets.AutoShowBanner(bannerProps)
		}
	}
}
