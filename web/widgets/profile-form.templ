package widgets

templ ProfileForm() {
	<form method="post" hx-post="/api/v1/profile">
		<div class="page-main__profile">
			<div class="setup-card">
				<div class="setup-intro">
					<p class="setup-step-label">First Run · Setup</p>
					<h1 class="setup-title">Surveyor Profile</h1>
					<p class="setup-description">
						This information will appear on all generated reports.
						You only need to fill this in once — it can be edited later in Settings.
					</p>
				</div>
				<div class="form-card">
					<!-- Personal Information -->
					<div class="form-section">
						<p class="form-section-title">Personal Information</p>
						<div class="field-row">
							<div class="field">
								<label for="first-name">First Name <span class="required">*</span></label>
								<input type="text" id="first-name" name="first_name" placeholder="e.g. Alexey" autocomplete="given-name" required/>
							</div>
							<div class="field">
								<label for="last-name">Last Name <span class="required">*</span></label>
								<input type="text" id="last-name" name="last_name" placeholder="e.g. Ivanov" autocomplete="family-name" required/>
							</div>
						</div>
						<div class="field">
							<label for="position">Position / Title <span class="optional">(optional)</span></label>
							<input type="text" id="position" name="position" placeholder="e.g. Senior Marine Surveyor"/>
						</div>
						<div class="field">
							<label for="email">Email <span class="optional">(optional)</span></label>
							<input type="email" id="email" name="email" placeholder="surveyor@example.com" autocomplete="email"/>
							<p class="field-hint">Used in reports only. Stored locally, never transmitted to any server.</p>
						</div>
					</div>
					<!-- Company & Certification -->
					<div class="form-section">
						<p class="form-section-title">Company & Certification</p>
						<div class="field">
							<label for="company">Company Name <span class="optional">(optional)</span></label>
							<input
								type="text"
								id="company"
								name="company"
								placeholder="e.g. Marine Survey Services Ltd."
								autocomplete="organization"
							/>
						</div>
						<div class="field-row">
							<div class="field">
								<label for="license-no">Licence / Certificate No. <span class="optional">(optional)</span></label>
								<input type="text" id="license-no" name="license_no" placeholder="e.g. CRS-00421"/>
							</div>
							<div class="field">
								<label for="country">Country <span class="optional">(optional)</span></label>
								<div class="select-wrap">
									<select id="country" name="country">
										<option value="" disabled selected>Select country</option>
										<option>Russia</option>
										<option>Netherlands</option>
										<option>Singapore</option>
										<option>United Kingdom</option>
										<option>Germany</option>
										<option>Switzerland</option>
										<option>Other</option>
									</select>
								</div>
							</div>
						</div>
					</div>
					<!-- Signature -->
					<div class="form-section">
						<p class="form-section-title">
							Signature for Reports <span
	style="font-weight:400;text-transform:none;letter-spacing:0;font-size:10px"
>(optional)</span>
						</p>
						<label for="signature-file" class="signature-upload">
							<input type="file" id="signature-file" name="signature" accept="image/png,image/jpeg"/>
							<svg class="signature-upload-icon" viewBox="0 0 24 24">
								<path d="M12 15V3M7 8l5-5 5 5"></path>
								<path d="M4 17v1a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-1"></path>
							</svg>
							<p class="signature-upload-text">Click to upload signature image</p>
							<p class="signature-upload-hint">PNG with transparent background recommended · max 2 MB</p>
						</label>
					</div>
					<!-- Form footer -->
					<div class="form-footer">
						<span class="form-footer-hint">
							Fields marked <span style="color:var(--accent)">*</span> are required
						</span>
						<button class="btn btn-primary" type="submit">
							<svg viewBox="0 0 24 24">
								<path d="M5 12h14M12 5l7 7-7 7"></path>
							</svg>
							Save & Continue
						</button>
					</div>
				</div><!-- /form-card -->
				<!-- Info note -->
				<div class="info-banner">
					<svg viewBox="0 0 24 24">
						<circle cx="12" cy="12" r="10"></circle>
						<path d="M12 16v-4M12 8h.01"></path>
					</svg>
					<p class="info-banner-text">
						All profile data is stored locally on this device only.
						No information is transmitted to external servers.
					</p>
				</div>
			</div><!-- /setup-card -->
		</div>
	</form>
}
