package widgets

templ SurveyListForm() {
	<main class="page-main__survey-list">
		<div class="page-content__survey-list">
			<!-- PAGE TOP -->
			<div class="page-top__survey-list">
				<div>
					<h1 class="page-title">Surveys</h1>
					<p class="page-meta">All draft survey reports · Alexey Zotov</p>
				</div>
				<a href="new-survey.html" class="btn btn-primary">
					<svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"></path></svg>
					New Survey
				</a>
			</div>
			<!-- STATS -->
			<div class="stats-row">
				<div class="stat-card">
					<div class="stat-icon stat-icon--total"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg></div>
					<div><div class="stat-val" id="cnt-total">8</div><div class="stat-lbl">Total surveys</div></div>
				</div>
				<div class="stat-card">
					<div class="stat-icon stat-icon--done"><svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg></div>
					<div><div class="stat-val" id="cnt-complete">5</div><div class="stat-lbl">Complete</div></div>
				</div>
				<div class="stat-card">
					<div class="stat-icon stat-icon--active"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></div>
					<div><div class="stat-val" id="cnt-progress">2</div><div class="stat-lbl">In progress</div></div>
				</div>
				<div class="stat-card">
					<div class="stat-icon stat-icon--draft"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg></div>
					<div><div class="stat-val" id="cnt-draft">1</div><div class="stat-lbl">Draft</div></div>
				</div>
			</div>
			<!-- TOOLBAR -->
			<div class="toolbar">
				<div class="search-wrap">
					<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg>
					<input class="search-in" type="text" id="search" placeholder="Search vessel, port, IMO…" oninput="filterSurveys()"/>
				</div>
				<select class="filter-sel" id="filter-op" onchange="filterSurveys()">
					<option value="">All Operations</option>
					<option value="Loading">Loading</option>
					<option value="Discharging">Discharging</option>
				</select>
				<select class="filter-sel" id="filter-status" onchange="filterSurveys()">
					<option value="">All Statuses</option>
					<option value="Complete">Complete</option>
					<option value="In Progress">In Progress</option>
					<option value="Draft">Draft</option>
				</select>
				<div class="tb-spacer"></div>
				<div class="view-toggle">
					<button class="vt-btn active" id="vt-table" onclick="setView('table')" title="Table view">
						<svg viewBox="0 0 24 24"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"></path></svg>
					</button>
					<button class="vt-btn" id="vt-grid" onclick="setView('grid')" title="Card view">
						<svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
					</button>
				</div>
			</div>
			<div class="results-count" id="results-count"><b>8</b> surveys found</div>
			<!-- TABLE VIEW -->
			<div class="surveys-table-wrap" id="table-view">
				<table class="surveys-tbl">
					<thead>
						<tr>
							<th>Vessel</th>
							<th>Date</th>
							<th>Port</th>
							<th>Operation</th>
							<th class="th-r">Cargo, MT</th>
							<th class="th-r">Discrepancy</th>
							<th>Status</th>
							<th></th>
						</tr>
					</thead>
					<tbody id="tbl-body">
						<!-- rendered by JS -->
					</tbody>
				</table>
				<div class="empty-state" id="tbl-empty">
					<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg>
					<div class="empty-title">No surveys found</div>
					<div class="empty-sub">Try adjusting your search or filters</div>
				</div>
			</div>
			<!-- CARD VIEW -->
			<div class="surveys-grid" id="grid-view">
				<!-- rendered by JS -->
			</div>
		</div>
	</main>
	<script src="/static/js/survey-list.js"></script>
}
