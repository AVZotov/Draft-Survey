package widgets

import (
	"fmt"
	"github.com/AVZotov/draft-survey/internal/types"
	"github.com/AVZotov/draft-survey/web/components"
)

templ DraftForm(survey *types.Survey) {
	<main class="page-main__drafts">
		<form id="draft-form">
			<div class="drafts-wrap">
				<div class="page-top__drafts">
					<a href="#" class="back-link">
						<svg viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg>
						Back to Survey Data
					</a>
					<h1 class="page-title">Draft Readings</h1>
					<p class="page-meta">{ survey.VesselData.Name } · IMO { survey.VesselData.IMO } · { survey.CargoOperation.Operation } · { survey.CargoOperation.PlaceOfInspection }</p>
				</div>
				for i, draft := range survey.Drafts {
					if i > 0 {
						<div class="draft-divider">
							<div class="dd-line"></div>
							<span class="dd-label">↓ { draftDividerLabel(i, len(survey.Drafts)) }</span>
							<div class="dd-line"></div>
						</div>
					}
					@DraftBlock(components.DraftBlockProps{
						Draft:  draft,
						Index:  i,
						Prefix: draftPrefix(i, len(survey.Drafts)),
					})
				}
			</div>
		</form>
	</main>
}

func draftPrefix(i, total int) string {
	if i == 0 {
		return "i"
	}
	if i == total-1 {
		return "f"
	}
	return fmt.Sprintf("m%d", i)
}

func draftDividerLabel(i, total int) string {
	if i == total-1 {
		return "Final Draft"
	}
	return fmt.Sprintf("Draft %d", i+1)
}
