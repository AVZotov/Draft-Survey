package widgets

import (
	"github.com/AVZotov/draft-survey/internal/calculation"
	"github.com/AVZotov/draft-survey/internal/types"
)

templ ResultsDraftCol(draft types.Draft, result calculation.DraftResult) {
	<div
		class={ templ.Classes("draft-col", 
      templ.KV("draft-col--ini", draft.Type == types.DraftTypeInitial),
      templ.KV("draft-col--fin", draft.Type != types.DraftTypeInitial),
      ) }
	>
		<div class="draft-col-header">
			<div class="col-label">
				<span class="col-dot"></span>
				if draft.Type == types.DraftTypeInitial {
					Initial Draft
				} else {
					Final Draft
				}
			</div>
			<span class="col-mmc">MMC 6.323 m · (6M/8) Full LBP</span>
		</div>
		<div class="draft-col-body">
			<!-- Step 1 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">1</span>
					<span class="step-title">Observed Drafts &amp; Means</span>
					<span class="step-status ok">OK</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label indent">Fwd P / Fwd S</span><span class="vrow-value">10.260 / 10.150 m</span></div>
					<div class="vrow"><span class="vrow-label indent">Mid P / Mid S</span><span class="vrow-value">10.380 / 9.070 m</span></div>
					<div class="vrow"><span class="vrow-label indent">Aft P / Aft S</span><span class="vrow-value">10.290 / 10.110 m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">meanF</span><span class="vrow-value">10.205 m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">meanM</span><span class="vrow-value">9.725 m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">meanA</span><span class="vrow-value">10.200 m</span></div>
				</div>
			</div>
			<!-- Step 2-3 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">2–3</span>
					<span class="step-title">PP &amp; Keel Corrections</span>
					<span class="step-status ok">Applied</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label indent">dFwd 5.380 m A · Fk 0.0 mm</span><span class="vrow-formula">corrPP + corrKeel</span></div>
					<div class="vrow"><span class="vrow-label indent">dMid 1.090 m A · Mk 0.0 mm</span><span class="vrow-formula">corrPP + corrKeel</span></div>
					<div class="vrow"><span class="vrow-label indent">dAft 1.800 m A · Ak 0.0 mm</span><span class="vrow-formula">corrPP + corrKeel</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">FWD corrected wKeel</span><span class="vrow-value">10.205 m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">MID corrected wKeel</span><span class="vrow-value">9.725 m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">AFT corrected wKeel</span><span class="vrow-value">10.200 m</span></div>
				</div>
			</div>
			<!-- Step 4 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">4</span>
					<span class="step-title">List &amp; Trim</span>
					<span class="step-status ok">Upright · 0.005 m Aft</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label">Obs. Trim</span><span class="vrow-value">0.005 m Aft</span></div>
					<div class="vrow"><span class="vrow-label">True Trim</span><span class="vrow-value">0.005 m Aft</span></div>
					<div class="vrow"><span class="vrow-label">List</span><span class="vrow-value dim">Upright</span></div>
					<div class="vrow"><span class="vrow-label">Deflection (Hogging)</span><span class="vrow-value warn">47.8 cm ⚠</span></div>
				</div>
			</div>
			<!-- Step 5-6 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">5–6</span>
					<span class="step-title">Mean of Means &amp; MMC</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label">Mean F&amp;A</span><span class="vrow-value">10.203 m</span></div>
					<div class="vrow"><span class="vrow-label">MM (mean of means)</span><span class="vrow-value">9.964 m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label bold">MMC wKeel</span><span class="vrow-value">6.323 m</span></div>
					<div class="vrow"><span class="vrow-label dim">Formula: (F + 6M + A) / 8 — standard</span><span class="vrow-formula">Full LBP</span></div>
				</div>
			</div>
			<!-- Step 7 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">7</span>
					<span class="step-title">Hydrostatic Interpolation at MMC 6.323 m</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label indent">Upper: 6.322 m</span><span class="vrow-value">33 094.800 MT · TPC 56.300 · LCF 6.070 m F</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label bold">MMC interpolated</span><span class="vrow-value">33 099.026 MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Lower: 6.422 m</span><span class="vrow-value">33 376.500 MT · TPC 56.400 · LCF 5.999 m F</span></div>
					<div class="vrow"><span class="vrow-label">TPC at MMC</span><span class="vrow-value">56.302 MT/cm</span></div>
					<div class="vrow"><span class="vrow-label">LCF/LCA at MMC</span><span class="vrow-value">6.069 m F</span></div>
					<div class="vrow"><span class="vrow-label">ΔMTC (direct)</span><span class="vrow-value">34.800 MT·m</span></div>
				</div>
			</div>
			<!-- Step 8 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">8</span>
					<span class="step-title">Trim &amp; List Corrections</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label indent">1st Trim Correction</span><span class="vrow-value neg">−479.246 MT</span></div>
					<div class="vrow"><span class="vrow-label dim indent">trim by stern, FTC applied</span></div>
					<div class="vrow"><span class="vrow-label indent">2nd Trim Correction</span><span class="vrow-value">1.141 MT</span></div>
					<div class="vrow"><span class="vrow-label indent">List Correction</span><span class="vrow-value dim">0.000 MT</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label bold">Total Trim &amp; List Correction</span><span class="vrow-value neg">−478.105 MT</span></div>
					<div class="vrow vrow--total"><span class="vrow-label">Displ. corr'd to Trim &amp; List</span><span class="vrow-value">32 620.921 MT</span></div>
				</div>
			</div>
			<!-- Step 9 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">9</span>
					<span class="step-title">Density Correction</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label">Table Density</span><span class="vrow-value">1.025 t/m³</span></div>
					<div class="vrow"><span class="vrow-label">Dockwater Density</span><span class="vrow-value">1.025 t/m³</span></div>
					<div class="vrow"><span class="vrow-label dim">FWA = Summer DWT / (4 × Summer TPC)</span><span class="vrow-value dim">182.5 mm</span></div>
					<div class="vrow"><span class="vrow-label dim">DWA = FWA × (tableDens − Density) / (tableDens − 1)</span><span class="vrow-value dim">0.000 mm</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">Density Correction</span><span class="vrow-value dim">0.000 MT</span></div>
					<div class="vrow vrow--total"><span class="vrow-label">Displ. corr'd to Density</span><span class="vrow-value">32 620.921 MT</span></div>
				</div>
			</div>
			<!-- Step 10 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">10</span>
					<span class="step-title">Deductibles</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label indent">HFO</span><span class="vrow-value">856.300 MT</span></div>
					<div class="vrow"><span class="vrow-label indent">MDO</span><span class="vrow-value">98.200 MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Lube Oil</span><span class="vrow-value">12.000 MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Fresh Water</span><span class="vrow-value">364.000 MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Ballast Water</span><span class="vrow-value">10 606.596 MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Bilge Water</span><span class="vrow-value dim">0.000 MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Constant Declared</span><span class="vrow-value">490.000 MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Others</span><span class="vrow-value dim">0.000 MT</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label bold">Total Deductibles</span><span class="vrow-value">12 427.096 MT</span></div>
				</div>
			</div>
			<!-- Step 11-12 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">11–12</span>
					<span class="step-title">Net Displacement &amp; Current DWT</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow vrow--total"><span class="vrow-label">Net Displacement</span><span class="vrow-value">20 193.825 MT</span></div>
					<div class="vrow"><span class="vrow-label dim">Current DWT = Displ. corr'd to Density − Lightship</span><span class="vrow-value dim">16 983.921 MT</span></div>
				</div>
			</div>
			<!-- Step 13 -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">13</span>
					<span class="step-title">Constant Check</span>
					<span class="step-status warn">10% up to declared</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label">Constant Declared</span><span class="vrow-value">490.000 MT</span></div>
					<div class="vrow"><span class="vrow-label">Cargo Declared (S/P)</span><span class="vrow-value">78 549.200 MT</span></div>
					<div class="vrow"><span class="vrow-label">Lightship</span><span class="vrow-value">15 637.000 MT</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label bold">Constant Calculated</span><span class="vrow-value warn">480.090 MT</span></div>
					<div class="vrow"><span class="vrow-label dim">Constant 10% up to than declared</span></div>
				</div>
			</div>
		</div><!-- /draft-col-body -->
	</div>
}
