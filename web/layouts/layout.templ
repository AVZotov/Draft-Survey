package layouts

import (
	"github.com/AVZotov/draft-survey/web/components"
	"github.com/AVZotov/draft-survey/web/widgets"
)

//"github.com/AVZotov/draft-survey/web/widgets"
templ Layout(props components.LayoutProps) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
			<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
			<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
			<link rel="stylesheet" href="/static/css/styles.css"/>
			<link rel="stylesheet" href="/static/css/banner.css"/>
			<!--Modals CSS section -->
			<link rel="stylesheet" href="/static/css/tank-calc-modal.css"/>
			for _, css := range props.ExtraCSS {
				<link rel="stylesheet" href={ css }/>
			}
			<script src="/static/js/main.js"></script>
			<script src="/static/js/htmx.min.js"></script>
			<script src="/static/js/idiomorph-ext.js"></script>
			<script defer src="/static/js/alpine.min.js"></script>
			<!--Modals scripts section -->
			<script defer src="/static/js/tank-calc-modal.js"></script>
			<title>{ props.Title }</title>
			<meta name="Draft-Survey calculator" content={ props.MetaDescription }/>
		</head>
		<body
			hx-ext="morph"
		>
			@widgets.Banner()
			{ children... }
			<!-- Universl modal dialog -->
			<dialog
				id="app-modal"
				hx-preserve="true"
				x-data="{dirty: false}"
				x-on:close="dirty = false"
				x-on:cancel.prevent="
				if (!dirty) {$el.close(); return }
				if (confirm('Unsaved changes. Close anyway?')) { $el.close() }
				"
			>
				<div id="app-modal-content"></div>
			</dialog>
			<!-- Universl toast/notification -->
			<dialog id="app-toast" hx-preserve="true">
				<div id="app-toast-content"></div>
			</dialog>
			for _, js := range props.ExtraJS {
				<script src={ js }></script>
			}
		</body>
	</html>
}
