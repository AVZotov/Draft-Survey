package web

import "github.com/AVZotov/draft-survey/web/layouts"
import "github.com/AVZotov/draft-survey/web/widgets"
import "github.com/AVZotov/draft-survey/web/components"

templ Results(props components.LayoutProps) {
	@layouts.Layout(props) {
		@widgets.HeaderUser(props.User)
		@widgets.ResultsForm(props)
		@widgets.ResultsEditPanel(props)
		@widgets.ResultsActionBar(props.Survey)
		@widgets.Footer()
	}
}
