package pages

import (
	"fmt"
	"github.com/AVZotov/draft-survey/internal/calculation"
	"github.com/AVZotov/draft-survey/internal/types"
	"github.com/AVZotov/draft-survey/web/components"
	"github.com/AVZotov/draft-survey/web/layouts"
	"github.com/AVZotov/draft-survey/web/widgets"
	"strings"
)

templ ResultsPage(props components.LayoutProps) {
	@layouts.Layout(props) {
		<!-- APP HEADER -->
		<header class="app-header">
			<div class="app-header-left">
				<div class="app-logo-mark">
					<svg viewBox="0 0 24 24">
						<path d="M3 17l2-7h14l2 7H3z"></path>
						<path d="M8 10V6h8v4"></path>
						<path d="M12 6V3"></path>
						<path d="M1 20c2 1.5 4 1.5 6 0s4-1.5 6 0 4 1.5 6 0"></path>
					</svg>
				</div>
				<div class="app-logo-text">
					<span class="app-logo-name">Draft Survey</span>
					<span class="app-logo-tagline">Cargo Weight Calculator</span>
				</div>
			</div>
			<div class="app-header-right">
				if props.Survey != nil {
					<div class="survey-pill">
						<span class="pill-vessel">{ props.Survey.VesselData.Name }</span>
						<span class="op-badge">{ props.Survey.CargoOperation.Operation }</span>
						<span class="pill-port">{ props.Survey.CargoOperation.PlaceOfInspection }</span>
					</div>
				}
				<div class="header-divider"></div>
				if props.User != nil {
					<div class="header-user">
						<div class="header-user-avatar">{ firstLetterR(props.User.FirstName) }{ firstLetterR(props.User.LastName) }</div>
						<div class="header-user-info">
							<span class="header-user-name">{ props.User.FirstName } { props.User.LastName }</span>
							<span class="header-user-role">{ props.User.Position }</span>
						</div>
					</div>
				}
				<div class="header-divider"></div>
				<span class="app-header-version">v0.1.0</span>
			</div>
		</header>
		<!-- SURVEY SELECTOR BAR -->
		<div class="selector-bar">
			<span class="selector-label">Compare</span>
			<div class="selector-group">
				<span class="phase-badge phase-badge--ini">Initial</span>
				<div class="sel-wrap">
					<select id="sel-ini" onchange="updateSelector()">
						if props.Survey != nil {
							for i, d := range props.Survey.Drafts {
								if d.Type == "initial" {
									<!-- TODO: show MMC from props.Results -->
									<option value={ fmt.Sprintf("ini-%d", i) } selected>
										{ d.StartedAt.Format("02 Jan 2006") } — MMC (calculated)
									</option>
								}
							}
						}
					</select>
				</div>
			</div>
			<div class="selector-divider"></div>
			<div class="selector-group">
				<span class="phase-badge phase-badge--fin">Final</span>
				<div class="sel-wrap">
					<select id="sel-fin" onchange="updateSelector()">
						if props.Survey != nil {
							for i, d := range props.Survey.Drafts {
								if d.Type == "final" {
									<!-- TODO: show MMC from props.Results -->
									<option value={ fmt.Sprintf("fin-%d", i) } selected>
										{ d.StartedAt.Format("02 Jan 2006") } — MMC (calculated)
									</option>
								}
							}
						}
					</select>
				</div>
			</div>
			<div class="selector-actions">
				<button class="btn btn-ghost btn-sm" onclick="openEditPanel()">
					<svg viewBox="0 0 24 24">
						<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
						<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
					</svg>
					Edit Drafts
				</button>
			</div>
		</div>
		<!-- MAIN -->
		<main class="page-main__results">
			<!-- Alerts -->
			<!-- TODO: bind alerts dynamically based on constant check, DWT, list results -->
			<div class="global-alerts">
				<div class="alert alert--warn">
					<svg viewBox="0 0 24 24">
						<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
						<path d="M12 9v4M12 17h.01"></path>
					</svg>
					Constant 10% up to declared — verify vessel constant before signing report
				</div>
				<div class="alert alert--ok">
					<svg viewBox="0 0 24 24">
						<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
						<polyline points="22 4 12 14.01 9 11.01"></polyline>
					</svg>
					Summer DWT not exceeded · Upright vessel · No LOP required
				</div>
			</div>
			<!-- Side-by-side columns -->
			<div class="results-grid">
				if props.Results != nil && len(*props.Results) >= 1 {
					@draftColumn("ini", "Initial Draft", (*props.Results)[0], props)
				}
				if props.Results != nil && len(*props.Results) >= 2 {
					@draftColumn("fin", "Final Draft", (*props.Results)[1], props)
				}
			</div>
			<!-- CARGO RESULT -->
			if props.Results != nil && len(*props.Results) >= 2 {
				@cargoSection((*props.Results)[0], (*props.Results)[1], props)
			}
		</main>
		<!-- ACTION BAR -->
		<div class="action-bar">
			<div class="action-bar-info">
				if props.Survey != nil {
					<span class="ab-vessel">{ props.Survey.VesselData.Name }</span>
					<span class="ab-meta">
						IMO { props.Survey.VesselData.IMO } · { props.Survey.CargoOperation.Operation } · { props.Survey.CargoOperation.PlaceOfInspection }
					</span>
				}
			</div>
			<div class="action-bar-btns">
				<button class="btn btn-ghost" onclick="history.back()">
					<svg viewBox="0 0 24 24">
						<path d="M19 12H5M12 19l-7-7 7-7"></path>
					</svg>
					Back to Drafts
				</button>
				<button class="btn btn-ghost">
					<svg viewBox="0 0 24 24">
						<path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v14a2 2 0 0 1-2 2z"></path>
						<path d="M17 21v-8H7v8M7 3v5h8"></path>
					</svg>
					Save
				</button>
				<button class="btn btn-ghost" onclick="openEditPanel()">
					<svg viewBox="0 0 24 24">
						<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
						<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
					</svg>
					Edit Drafts
				</button>
				<!-- Print dropdown -->
				<div class="print-wrap">
					<button class="btn btn-ghost" onclick="togglePrintMenu()">
						<svg viewBox="0 0 24 24">
							<polyline points="6 9 6 2 18 2 18 9"></polyline>
							<path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
							<rect x="6" y="14" width="12" height="8"></rect>
						</svg>
						Print Report
						<svg viewBox="0 0 24 24" style="width:10px;height:10px">
							<polyline points="6 9 12 15 18 9"></polyline>
						</svg>
					</button>
					<div class="print-menu" id="print-menu">
						<div class="print-menu-title">Select report type</div>
						<button class="print-item" onclick="printReport('ds')">
							<svg viewBox="0 0 24 24">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
								<polyline points="14 2 14 8 20 8"></polyline>
							</svg>
							<div>
								<div>Draft Survey Report</div>
								<div class="print-item-desc">Official report for signing</div>
							</div>
						</button>
						<button class="print-item" onclick="printReport('internal')">
							<svg viewBox="0 0 24 24">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
								<polyline points="14 2 14 8 20 8"></polyline>
								<line x1="16" y1="13" x2="8" y2="13"></line>
								<line x1="16" y1="17" x2="8" y2="17"></line>
							</svg>
							<div>
								<div>Draft Survey — Internal Use</div>
								<div class="print-item-desc">Working copy with full calculation detail</div>
							</div>
						</button>
						<button class="print-item" onclick="printReport('ballast')">
							<svg viewBox="0 0 24 24">
								<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
								<polyline points="9 22 9 12 15 12 15 22"></polyline>
							</svg>
							<div>
								<div>Ballast Tanks Report</div>
								<div class="print-item-desc">BW / FW tanks breakdown</div>
							</div>
						</button>
					</div>
				</div>
				<button class="btn btn-primary" onclick="openEditPanel()">
					<svg viewBox="0 0 24 24">
						<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
						<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
					</svg>
					Edit &amp; Recalculate
				</button>
			</div>
		</div>
		<!-- EDIT PANEL -->
		<div class="panel-overlay" id="panel-overlay">
			<div class="panel-backdrop" onclick="closeEditPanel()"></div>
			<div class="edit-panel">
				<div class="panel-header">
					<div>
						<div class="panel-title">Edit Draft Readings</div>
						<div class="panel-subtitle">Changes recalculate automatically on backend</div>
					</div>
					<button class="panel-close" onclick="closeEditPanel()">
						<svg viewBox="0 0 24 24">
							<line x1="18" y1="6" x2="6" y2="18"></line>
							<line x1="6" y1="6" x2="18" y2="18"></line>
						</svg>
					</button>
				</div>
				<!-- Live result strip -->
				<div style="padding: 8px 16px; border-bottom: 1px solid var(--border); background: var(--bg); flex-shrink: 0;">
					<div class="panel-result-strip" style="margin-bottom:0">
						<div>
							<div class="prs-label">Cargo Loaded</div>
							<div class="prs-note">Recalculates on Submit</div>
						</div>
						<div style="text-align:right">
							if props.Results != nil && len(*props.Results) >= 2 {
								<div class="prs-value">{ fmt.Sprintf("%.3f", (*props.Results)[1].NetDisplacement-(*props.Results)[0].NetDisplacement) } MT</div>
							} else {
								<div class="prs-value pending">—</div>
							}
							<!-- TODO: bind discrepancy vs S/P -->
							<div class="prs-note" style="color:var(--success)">vs S/P (TODO)</div>
						</div>
					</div>
				</div>
				<!-- Tabs -->
				<div class="panel-tabs">
					<button class="panel-tab active" onclick="switchTab('ini', this)">● Initial Draft</button>
					<button class="panel-tab" onclick="switchTab('fin', this)">● Final Draft</button>
				</div>
				<div class="panel-body">
					<!-- Initial tab -->
					<div class="panel-tab-content active" id="tab-ini">
						if props.Survey != nil && len(props.Survey.Drafts) >= 1 {
							@draftEditPanel(props.Survey.Drafts[0])
						}
					</div>
					<!-- Final tab -->
					<div class="panel-tab-content" id="tab-fin">
						if props.Survey != nil && len(props.Survey.Drafts) >= 2 {
							@draftEditPanel(props.Survey.Drafts[1])
						}
					</div>
				</div>
				<div class="panel-footer">
					<button class="btn btn-ghost" style="flex:1" onclick="resetPanel()">
						<svg viewBox="0 0 24 24">
							<polyline points="1 4 1 10 7 10"></polyline>
							<path d="M3.51 15a9 9 0 1 0 .49-3.95"></path>
						</svg>
						Reset
					</button>
					<button class="btn btn-primary" style="flex:2" onclick="submitPanel()">
						<svg viewBox="0 0 24 24">
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
						Submit &amp; Recalculate
					</button>
				</div>
			</div>
		</div>
		@widgets.Footer()
	}
}

// draftColumn renders one Initial or Final draft calculation column.
templ draftColumn(phase string, label string, r calculation.DraftResult, props components.LayoutProps) {
	<div class={ "draft-col", "draft-col--" + phase }>
		<div class="draft-col-header">
			<div class="col-label">
				<span class="col-dot"></span>
				{ label }
			</div>
			<span class="col-mmc">
				MMC { fmt.Sprintf("%.3f", r.MMC) } m
				if props.Survey != nil {
					· ({ string(props.Survey.VesselData.CorrectionMethod) })
				}
			</span>
		</div>
		<div class="draft-col-body">
			<!-- Step 1: Observed Drafts & Means -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">1</span>
					<span class="step-title">Observed Drafts &amp; Means</span>
					<span class="step-status ok">OK</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<!-- TODO: bind Fwd/Mid/Aft P/S from props.Survey.Drafts[i].Marks -->
					<div class="vrow"><span class="vrow-label indent">Fwd P / Fwd S</span><span class="vrow-value">— / — m</span></div>
					<div class="vrow"><span class="vrow-label indent">Mid P / Mid S</span><span class="vrow-value">— / — m</span></div>
					<div class="vrow"><span class="vrow-label indent">Aft P / Aft S</span><span class="vrow-value">— / — m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">meanF</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.MeanDraft.DraftFwdMean) } m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">meanM</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.MeanDraft.DraftMidMean) } m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">meanA</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.MeanDraft.DraftAftMean) } m</span></div>
				</div>
			</div>
			<!-- Step 2-3: PP & Keel Corrections -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">2–3</span>
					<span class="step-title">PP &amp; Keel Corrections</span>
					<span class="step-status ok">Applied</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<!-- TODO: bind PP distances and keel values from props.Survey.Drafts[i] -->
					<div class="vrow"><span class="vrow-label indent">dFwd — · Fk — mm</span><span class="vrow-formula">corrPP + corrKeel</span></div>
					<div class="vrow"><span class="vrow-label indent">dMid — · Mk — mm</span><span class="vrow-formula">corrPP + corrKeel</span></div>
					<div class="vrow"><span class="vrow-label indent">dAft — · Ak — mm</span><span class="vrow-formula">corrPP + corrKeel</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">FWD corrected wKeel</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.DraftsWKeel.FwdDraftWKeel) } m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">MID corrected wKeel</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.DraftsWKeel.MidDraftWKeel) } m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label">AFT corrected wKeel</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.DraftsWKeel.AftDraftWKeel) } m</span></div>
				</div>
			</div>
			<!-- Step 4: List & Trim -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">4</span>
					<span class="step-title">List &amp; Trim</span>
					<!-- TODO: bind status text based on r.ListMeters and trim direction -->
					<span class="step-status ok">{ fmt.Sprintf("%.3f", r.TrueTrim) } m</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow"><span class="vrow-label">Obs. Trim</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.ObservedTrim) } m</span></div>
					<div class="vrow"><span class="vrow-label">True Trim</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.TrueTrim) } m</span></div>
					<div class="vrow">
						<span class="vrow-label">List</span>
						if r.ListMeters == 0 {
							<span class="vrow-value dim">Upright</span>
						} else {
							<span class="vrow-value">{ fmt.Sprintf("%.3f", r.ListMeters) } m / { fmt.Sprintf("%.1f", r.ListDegrees) }°</span>
						}
					</div>
					<div class="vrow">
						<span class="vrow-label">Deflection</span>
						<!-- TODO: label Hogging/Sagging based on deflection sign -->
						if r.Deflection != 0 {
							<span class="vrow-value warn">{ fmt.Sprintf("%.1f", r.Deflection) } cm ⚠</span>
						} else {
							<span class="vrow-value dim">0.0 cm</span>
						}
					</div>
				</div>
			</div>
			<!-- Step 5-6: Mean of Means & MMC -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">5–6</span>
					<span class="step-title">Mean of Means &amp; MMC</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<!-- TODO: bind Mean F&A and MM intermediate values separately -->
					<div class="vrow"><span class="vrow-label">Mean F&amp;A</span><span class="vrow-value">— m</span></div>
					<div class="vrow"><span class="vrow-label">MM (mean of means)</span><span class="vrow-value">— m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label bold">MMC wKeel</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.MMC) } m</span></div>
					if props.Survey != nil {
						<div class="vrow"><span class="vrow-label dim">Formula: (F + 6M + A) / 8 — standard</span><span class="vrow-formula">{ string(props.Survey.VesselData.CorrectionMethod) }</span></div>
					}
				</div>
			</div>
			<!-- Step 7: Hydrostatic Interpolation -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">7</span>
					<span class="step-title">Hydrostatic Interpolation at MMC { fmt.Sprintf("%.3f", r.MMC) } m</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<!-- TODO: bind upper/lower hydrostatic rows from props.Survey.Drafts[i].HydrostaticRows -->
					<div class="vrow"><span class="vrow-label indent">Upper: — m</span><span class="vrow-value">— MT · TPC — · LCF — m</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label bold">MMC interpolated</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.Hydrostatics.Displacement) } MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Lower: — m</span><span class="vrow-value">— MT · TPC — · LCF — m</span></div>
					<div class="vrow"><span class="vrow-label">TPC at MMC</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.Hydrostatics.TPC) } MT/cm</span></div>
					<div class="vrow"><span class="vrow-label">LCF/LCA at MMC</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.Hydrostatics.LCF) } m</span></div>
					<!-- TODO: bind ΔMTC from MTCRows interpolation -->
					<div class="vrow"><span class="vrow-label">ΔMTC (direct)</span><span class="vrow-value">— MT·m</span></div>
				</div>
			</div>
			<!-- Step 8: Trim & List Corrections -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">8</span>
					<span class="step-title">Trim &amp; List Corrections</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow">
						<span class="vrow-label indent">1st Trim Correction</span>
						if r.FirstTrimCorrection < 0 {
							<span class="vrow-value neg">{ fmt.Sprintf("%.3f", r.FirstTrimCorrection) } MT</span>
						} else {
							<span class="vrow-value">{ fmt.Sprintf("%.3f", r.FirstTrimCorrection) } MT</span>
						}
					</div>
					<div class="vrow">
						<span class="vrow-label indent">2nd Trim Correction</span>
						<span class="vrow-value">{ fmt.Sprintf("%.3f", r.SecondTrimCorrection) } MT</span>
					</div>
					<div class="vrow">
						<span class="vrow-label indent">List Correction</span>
						if r.ListCorrection == 0 {
							<span class="vrow-value dim">0.000 MT</span>
						} else {
							<span class="vrow-value">{ fmt.Sprintf("%.3f", r.ListCorrection) } MT</span>
						}
					</div>
					<div class="vrow vrow--sub">
						<span class="vrow-label bold">Total Trim &amp; List Correction</span>
						if r.TotalTrimCorrection < 0 {
							<span class="vrow-value neg">{ fmt.Sprintf("%.3f", r.TotalTrimCorrection) } MT</span>
						} else {
							<span class="vrow-value">{ fmt.Sprintf("%.3f", r.TotalTrimCorrection) } MT</span>
						}
					</div>
					<div class="vrow vrow--total">
						<span class="vrow-label">Displ. corr'd to Trim &amp; List</span>
						<span class="vrow-value">{ fmt.Sprintf("%.3f", r.Hydrostatics.Displacement+r.TotalTrimCorrection) } MT</span>
					</div>
				</div>
			</div>
			<!-- Step 9: Density Correction -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">9</span>
					<span class="step-title">Density Correction</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<!-- TODO: bind table density from vessel data; dockwater from props.Survey.Drafts[i].Density -->
					<div class="vrow"><span class="vrow-label">Table Density</span><span class="vrow-value">— t/m³</span></div>
					<div class="vrow"><span class="vrow-label">Dockwater Density</span><span class="vrow-value">— t/m³</span></div>
					<!-- TODO: bind FWA and DWA -->
					<div class="vrow"><span class="vrow-label dim">FWA = Summer DWT / (4 × Summer TPC)</span><span class="vrow-value dim">— mm</span></div>
					<div class="vrow"><span class="vrow-label dim">DWA = FWA × (tableDens − Density) / (tableDens − 1)</span><span class="vrow-value dim">— mm</span></div>
					<div class="vrow vrow--sub">
						<span class="vrow-label">Density Correction</span>
						if r.DensityCorrection == 0 {
							<span class="vrow-value dim">0.000 MT</span>
						} else {
							<span class="vrow-value">{ fmt.Sprintf("%.3f", r.DensityCorrection) } MT</span>
						}
					</div>
					<div class="vrow vrow--total">
						<span class="vrow-label">Displ. corr'd to Density</span>
						<span class="vrow-value">{ fmt.Sprintf("%.3f", r.DisplacementCorrected) } MT</span>
					</div>
				</div>
			</div>
			<!-- Step 10: Deductibles -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">10</span>
					<span class="step-title">Deductibles</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<!-- TODO: bind deductibles from props.Survey.Drafts[i].Deductibles and tanks -->
					<div class="vrow"><span class="vrow-label indent">HFO</span><span class="vrow-value">— MT</span></div>
					<div class="vrow"><span class="vrow-label indent">MDO</span><span class="vrow-value">— MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Lube Oil</span><span class="vrow-value">— MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Fresh Water</span><span class="vrow-value">— MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Ballast Water</span><span class="vrow-value">— MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Bilge Water</span><span class="vrow-value dim">— MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Constant Declared</span><span class="vrow-value">— MT</span></div>
					<div class="vrow"><span class="vrow-label indent">Others</span><span class="vrow-value dim">— MT</span></div>
					<div class="vrow vrow--sub"><span class="vrow-label bold">Total Deductibles</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.TotalDeductibles) } MT</span></div>
				</div>
			</div>
			<!-- Step 11-12: Net Displacement & Current DWT -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">11–12</span>
					<span class="step-title">Net Displacement &amp; Current DWT</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<div class="vrow vrow--total"><span class="vrow-label">Net Displacement</span><span class="vrow-value">{ fmt.Sprintf("%.3f", r.NetDisplacement) } MT</span></div>
					<div class="vrow"><span class="vrow-label dim">Current DWT = Displ. corr'd to Density − Lightship</span><span class="vrow-value dim">{ fmt.Sprintf("%.3f", r.CurrentDWT) } MT</span></div>
				</div>
			</div>
			<!-- Step 13: Constant Check -->
			<div class="step">
				<div class="step-header" onclick="toggleStep(this)">
					<span class="step-num">13</span>
					<span class="step-title">Constant Check</span>
					<!-- TODO: bind status text/class (ok/warn) based on r.Constant vs declared -->
					<span class="step-status warn">{ fmt.Sprintf("%.3f", r.Constant) } MT</span>
					<svg class="step-chevron" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"></polyline></svg>
				</div>
				<div class="step-body">
					<!-- TODO: bind constant declared and cargo declared from survey draft -->
					<div class="vrow"><span class="vrow-label">Constant Declared</span><span class="vrow-value">— MT</span></div>
					<div class="vrow"><span class="vrow-label">Cargo Declared (S/P)</span><span class="vrow-value">— MT</span></div>
					if props.Survey != nil {
						<div class="vrow"><span class="vrow-label">Lightship</span><span class="vrow-value">{ fmt.Sprintf("%.3f", props.Survey.VesselData.Lightship) } MT</span></div>
					}
					<div class="vrow vrow--sub"><span class="vrow-label bold">Constant Calculated</span><span class="vrow-value warn">{ fmt.Sprintf("%.3f", r.Constant) } MT</span></div>
				</div>
			</div>
		</div>
	</div>
}

// cargoSection renders the cargo result summary panel below the side-by-side grid.
templ cargoSection(ini calculation.DraftResult, fin calculation.DraftResult, props components.LayoutProps) {
	<div class="cargo-section">
		<div class="cargo-hero">
			<div class="cargo-hero-left">
				<div>
					<div class="cargo-op-label">
						if props.Survey != nil {
							{ props.Survey.CargoOperation.Operation }
						} else {
							Cargo Loaded
						}
					</div>
					<div>
						<!-- TODO: format with space-separated thousands -->
						<span class="cargo-weight">{ fmt.Sprintf("%.3f", fin.NetDisplacement-ini.NetDisplacement) }</span>
						<span class="cargo-weight-unit">MT</span>
					</div>
				</div>
				<!-- TODO: bind discrepancy vs S/P (requires CargoDeclared from survey draft) -->
				<div class="cargo-disc ok">
					Discrepancy from S/P: <span>— MT / —%</span>
				</div>
			</div>
		</div>
		<div class="cargo-top">
			<div class="cargo-cell">
				<div class="cargo-cell-label">Initial Draft</div>
				<div class="cargo-cell-row"><span class="cargo-cell-name">Net Displacement</span><span class="cargo-cell-val">{ fmt.Sprintf("%.3f", ini.NetDisplacement) } MT</span></div>
				<div class="cargo-cell-row"><span class="cargo-cell-name">Current DWT</span><span class="cargo-cell-val dim">{ fmt.Sprintf("%.3f", ini.CurrentDWT) } MT</span></div>
				<div class="cargo-cell-row"><span class="cargo-cell-name">MMC</span><span class="cargo-cell-val">{ fmt.Sprintf("%.3f", ini.MMC) } m</span></div>
			</div>
			<div class="cargo-cell">
				<div class="cargo-cell-label">Final Draft</div>
				<div class="cargo-cell-row"><span class="cargo-cell-name">Net Displacement</span><span class="cargo-cell-val">{ fmt.Sprintf("%.3f", fin.NetDisplacement) } MT</span></div>
				<div class="cargo-cell-row"><span class="cargo-cell-name">Current DWT</span><span class="cargo-cell-val dim">{ fmt.Sprintf("%.3f", fin.CurrentDWT) } MT</span></div>
				<div class="cargo-cell-row"><span class="cargo-cell-name">MMC</span><span class="cargo-cell-val">{ fmt.Sprintf("%.3f", fin.MMC) } m</span></div>
			</div>
			<div class="cargo-cell">
				<!-- TODO: bind CargoDeclared and ConstantDeclared from props.Survey.Drafts -->
				<div class="cargo-cell-label">Declared</div>
				<div class="cargo-cell-row"><span class="cargo-cell-name">Cargo (S/P)</span><span class="cargo-cell-val">— MT</span></div>
				<div class="cargo-cell-row"><span class="cargo-cell-name">Constant Declared</span><span class="cargo-cell-val">— MT</span></div>
			</div>
			<div class="cargo-cell">
				<div class="cargo-cell-label">Constants</div>
				if props.Survey != nil {
					<div class="cargo-cell-row"><span class="cargo-cell-name">Lightship</span><span class="cargo-cell-val">{ fmt.Sprintf("%.3f", props.Survey.VesselData.Lightship) } MT</span></div>
				}
				<div class="cargo-cell-row"><span class="cargo-cell-name">Const. Calculated (ini)</span><span class="cargo-cell-val warn">{ fmt.Sprintf("%.3f", ini.Constant) } MT</span></div>
				<div class="cargo-cell-row"><span class="cargo-cell-name">Const. Checking (fin)</span><span class="cargo-cell-val warn">{ fmt.Sprintf("%.3f", fin.Constant) } MT</span></div>
			</div>
		</div>
	</div>
}

// draftEditPanel renders the edit form fields for one draft reading.
templ draftEditPanel(draft types.Draft) {
	<div class="panel-section-title">Observed Drafts</div>
	<div class="panel-field-row-3">
		<div class="panel-field">
			<label>Fwd Port, m</label>
			<input type="number" step="any" value={ fmtMarkVal(draft.Marks.FwdPort.Value) }/>
		</div>
		<div class="panel-field">
			<label>Mid Port, m</label>
			<input type="number" step="any" value={ fmtMarkVal(draft.Marks.MidPort.Value) }/>
		</div>
		<div class="panel-field">
			<label>Aft Port, m</label>
			<input type="number" step="any" value={ fmtMarkVal(draft.Marks.AftPort.Value) }/>
		</div>
	</div>
	<div class="panel-field-row-3">
		<div class="panel-field">
			<label>Fwd Starboard, m</label>
			<input type="number" step="any" value={ fmtMarkVal(draft.Marks.FwdStarboard.Value) }/>
		</div>
		<div class="panel-field">
			<label>Mid Starboard, m</label>
			<input type="number" step="any" value={ fmtMarkVal(draft.Marks.MidStarboard.Value) }/>
		</div>
		<div class="panel-field">
			<label>Aft Starboard, m</label>
			<input type="number" step="any" value={ fmtMarkVal(draft.Marks.AftStarboard.Value) }/>
		</div>
	</div>
	<div class="panel-section-title">Density</div>
	<div class="panel-field-row">
		<div class="panel-field">
			<label>Dockwater Density, t/m³</label>
			<input type="number" step="any" value={ fmtPtrVal(draft.Density) }/>
		</div>
		<!-- TODO: bind table density from vessel data (not stored in Draft struct) -->
		<div class="panel-field">
			<label>Table Density, t/m³</label>
			<input type="number" step="any" value="1.025"/>
		</div>
	</div>
	<div class="panel-section-title">Deductibles</div>
	<div class="panel-field-row">
		<div class="panel-field">
			<label>HFO, MT</label>
			<input type="number" step="any" value={ fmtPtrVal(draft.Deductibles.HFO) }/>
		</div>
		<div class="panel-field">
			<label>MDO, MT</label>
			<input type="number" step="any" value={ fmtPtrVal(draft.Deductibles.MDO) }/>
		</div>
	</div>
	<div class="panel-field-row">
		<div class="panel-field">
			<label>Lube Oil, MT</label>
			<input type="number" step="any" value={ fmtPtrVal(draft.Deductibles.LubOil) }/>
		</div>
		<!-- TODO: Fresh Water is sum of FreshWaterTanks, not a scalar field -->
		<div class="panel-field">
			<label>Fresh Water, MT</label>
			<input type="number" step="any" value="0.000"/>
		</div>
	</div>
	<div class="panel-field-row">
		<!-- TODO: Ballast Water is sum of BallastWaterTanks, not a scalar field -->
		<div class="panel-field">
			<label>Ballast Water, MT</label>
			<input type="number" step="any" value="0.000"/>
		</div>
		<div class="panel-field">
			<label>Bilge Water, MT</label>
			<input type="number" step="any" value={ fmtPtrVal(draft.Deductibles.BilgeWater) }/>
		</div>
	</div>
	<div class="panel-field-row">
		<div class="panel-field">
			<label>Constant Declared, MT</label>
			<input type="number" step="any" value={ fmtPtrVal(draft.ConstantDeclared) }/>
		</div>
		<div class="panel-field">
			<label>Others, MT</label>
			<input type="number" step="any" value={ fmtPtrVal(draft.Deductibles.Others) }/>
		</div>
	</div>
}

func firstLetterR(s string) string {
	if s == "" {
		return "?"
	}
	r := []rune(s)
	return strings.ToUpper(string(r[0]))
}

func fmtMarkVal(v *float64) string {
	if v == nil {
		return "0.000"
	}
	return fmt.Sprintf("%.3f", *v)
}

func fmtPtrVal(v *float64) string {
	if v == nil {
		return "0.000"
	}
	return fmt.Sprintf("%.3f", *v)
}
