package components

import (
	"fmt"
	"github.com/AVZotov/draft-survey/internal/constants"
	"github.com/AVZotov/draft-survey/internal/format"
	"github.com/AVZotov/draft-survey/internal/types"
)

templ TankItem(surveyID string, draftIndex int, tank types.Tank) {
	<tr
		id={ format.TankNameID("tank-row", tank) }
		hx-target="this"
		hx-trigger="change changed target:input delay:500ms"
		hx-sync="this:replace"
		hx-include="this"
		hx-swap="morph:outerHTML"
		hx-put={ fmt.Sprintf("/api/v1/survey/%s/tanks/%d/bw-tank/%s", surveyID, draftIndex, tank.ID) }
	>
		<td class="td-act">
			<button
				hx-get={ fmt.Sprintf("/survey/%s/tanks/%d/bw-tank/%s/corrections", surveyID, draftIndex, tank.ID) }
				hx-target="#app-modal-content"
				hx-on::after-request="document.getElementById('app-modal').showModal()"
				class="rbtn calc"
				type="button"
				title="Calculate volume"
			>
				<svg viewBox="0 0 24 24" width="13" height="13" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="4" y="2" width="16" height="20" rx="2"></rect>
					<line x1="8" y1="8" x2="16" y2="8"></line>
					<line x1="8" y1="12" x2="16" y2="12"></line>
					<line x1="8" y1="16" x2="12" y2="16"></line>
				</svg>
			</button>
		</td>
		<td class="td-name">
			<span class="t-name-label">{ tank.Type } { tank.Name }</span>
		</td>
		<td class="td-div"></td>
		<td>
			<input id={ format.TankNameID(constants.TankSounding, tank) } class="ti" type="number" name={ format.TankNameID(constants.TankSounding, tank) } value={ format.FloatOrEmpty(tank.Sounding) } placeholder="0.000" step="any"/>
		</td>
		<td>
			<input id={ format.TankNameID(constants.TankVolume, tank) } class="ti" type="number" name={ format.TankNameID(constants.TankVolume, tank) } value={ format.FloatOrEmpty(tank.Volume) } placeholder="Calculated" step="any"/>
		</td>
		<td>
			if tank.IsFWTTank {
				<input class="ti" type="number" readonly value="1"/>
			} else {
				<input id={ format.TankNameID(constants.TankDensity, tank) } class="ti" type="number" name={ format.TankNameID(constants.TankDensity, tank) } value={ format.FloatOrEmpty(tank.Density) } placeholder="0.000" step="any"/>
			}
		</td>
		<td>
			<input id={ format.TankNameID(constants.TankWeight, tank) } class="ti" type="text" readonly name={ format.TankNameID(constants.TankWeight, tank) } value={ format.WeightFormatted(tank.CalcWeight()) } placeholder="Calculated"/>
		</td>
		<td class="td-div"></td>
		<td class="td-act">
			<button
				hx-confirm="This operation can't be undone"
				hx-delete={ fmt.Sprintf("/api/v1/survey/%s/tanks/%d/bw-tank/%s", surveyID, draftIndex, tank.ID) }
				hx-target="closest tr"
				hx-swap="delete swap:500ms"
				class="rbtn remove"
				type="button"
				title="Remove"
			>-</button>
		</td>
	</tr>
}
